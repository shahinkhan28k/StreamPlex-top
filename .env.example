# =========================================================================
# StreamPlex - Hosting Environment Configuration Template
# =========================================================================
# আপনি যখন অন্য হোস্টিং প্যানেলে (cPanel, VPS, Netlify, Vercel বা অন্যান্য) এটি আপলোড করবেন,
# তখন এই ফাইলটি কপি করে '.env' নামে একটি নতুন ফাইল তৈরি করুন এবং সঠিক তথ্য বসিয়ে দিন।
#
# When deploying to other hosting panels, copy this file to '.env' and fill in correct values.

# 1. DATABASE CONFIGURATION (ডাটাবেজ কনফিগারেশন)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=streamplex_db
DB_USERNAME=streamplex_user
DB_PASSWORD=your_database_password_here

# 2. APP SERVER SETTINGS (সার্ভার সেটিংস)
PORT=3000
NODE_ENV=production
WEBSITE_URL=https://yourdomain.com

# 3. ROOT ADMIN SETUP (মাস্টার অ্যাডমিন লগইন)
DEFAULT_ADMIN_EMAIL=shahinkhan28r@gmail.com
DEFAULT_ADMIN_PASSWORD=adminpassword
